{
  "_version": "1.80.0",
  "sap.app": {
    "id": "zpurchaseorder.zpurchaseorder",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.20.4",
      "toolsId": "5ebb87d4-7d89-4141-a055-774ae7c77118"
    },
    "dataSources": {
      "annotation": {
        "type": "ODataAnnotation",
        "uri": "annotations/annotation.xml",
        "settings": {
          "localUri": "annotations/annotation.xml"
        }
      },
      "mainService": {
        "uri": "/sap/opu/odata4/sap/zui_purchaseorderh_o4/srvd/sap/zui_purchaseorderh_o4/0001/",
        "type": "OData",
        "settings": {
          "annotations": [
            "annotation"
          ],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "4.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "zpurchaseorder-display": {
          "semanticObject": "zpurchaseorder",
          "action": "display",
          "title": "{{zpurchaseorder-display.flpTitle}}",
          "subTitle": "{{zpurchaseorder-display.flpSubtitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.142.7",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "zpurchaseorder.zpurchaseorder.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "ZC_PURCHASEORDERHList",
          "target": "ZC_PURCHASEORDERHList"
        },
        {
          "pattern": "ZC_PURCHASEORDERH({key}):?query:",
          "name": "ZC_PURCHASEORDERHObjectPage",
          "target": "ZC_PURCHASEORDERHObjectPage"
        },
        {
          "pattern": "ZC_PURCHASEORDERH({key})/_item({key2}):?query:",
          "name": "ZC_PURCHASE_ITEMObjectPage",
          "target": "ZC_PURCHASE_ITEMObjectPage"
        }
      ],
      "targets": {
        "ZC_PURCHASEORDERHList": {
          "type": "Component",
          "id": "ZC_PURCHASEORDERHList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/ZC_PURCHASEORDERH",
              "variantManagement": "Page",
              "navigation": {
                "ZC_PURCHASEORDERH": {
                  "detail": {
                    "route": "ZC_PURCHASEORDERHObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  }
                }
              }
            }
          }
        },
        "ZC_PURCHASEORDERHObjectPage": {
          "type": "Component",
          "id": "ZC_PURCHASEORDERHObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/ZC_PURCHASEORDERH",
              "navigation": {
                "_item": {
                  "detail": {
                    "route": "ZC_PURCHASE_ITEMObjectPage"
                  }
                }
              }
            }
          }
        },
        "ZC_PURCHASE_ITEMObjectPage": {
          "type": "Component",
          "id": "ZC_PURCHASE_ITEMObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/ZC_PURCHASEORDERH/_item"
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
